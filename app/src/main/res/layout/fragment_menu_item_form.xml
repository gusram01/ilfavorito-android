<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    tools:context=".MenuItemFormFragment">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/menuItemFormLabelName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Nombre:"
        android:textSize="22dp"
        app:layout_constraintBottom_toTopOf="@+id/menuItemFormInputName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/menuItemFormInputName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Nombre..."
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@+id/menuItemFormLabelPrice"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menuItemFormLabelName" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/menuItemFormLabelPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Precio:"
        android:textSize="22dp"
        app:layout_constraintBottom_toTopOf="@+id/menuItemFormInputPrice"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menuItemFormInputName" />

    <EditText
        android:id="@+id/menuItemFormInputPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="0.0"
        android:inputType="numberDecimal"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@+id/menuItemFormLabelDescription"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menuItemFormLabelPrice" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/menuItemFormLabelDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Descripción:"
        android:textSize="22dp"
        app:layout_constraintBottom_toTopOf="@+id/menuItemFormInputDescription"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menuItemFormInputPrice" />

    <EditText
        android:id="@+id/menuItemFormInputDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Descripción..."
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@+id/menuItemFormLabelType"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menuItemFormLabelDescription" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/menuItemFormLabelType"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Tipo:"
        android:textSize="22dp"
        app:layout_constraintBottom_toTopOf="@+id/menuItemFormSpinnerType"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menuItemFormInputDescription" />

    <Spinner
        android:id="@+id/menuItemFormSpinnerType"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@+id/menuItemFormButtonsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menuItemFormLabelType" />

    <LinearLayout
        android:id="@+id/menuItemFormButtonsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menuItemFormSpinnerType">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/menuItemFormCreateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/menuItemFormEditButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Actualizar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/menuItemFormDeleteButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Eliminar" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
